{
  "name": "encdr",
  "version": "1.0.0",
  "description": "Video re-encoder with GUI using ffmpeg",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "video",
    "encoder",
    "ffmpeg",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "fluent-ffmpeg": "^2.1.2",
    "ffmpeg-static": "^5.1.0",
    "ffprobe-static": "^3.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.encdr.app",
    "productName": "ENCDR",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "portable",
        "installer"
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
